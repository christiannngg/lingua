# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------

# PostgreSQL connection string (Railway in production, local Postgres in dev).
# Must point to a database with the pgvector extension installed.
#
# Local dev example:  postgresql://postgres:password@localhost:5432/lingua_dev
# Railway example:    postgresql://postgres:<token>@<host>.railway.app:5432/railway
#
#   In Vercel, set DATABASE_URL to Production environment ONLY.
#     Do not share the production database with Preview deployments.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
POSTGRES_DB=lingua_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# -----------------------------------------------------------------------------
# ANTHROPIC
# -----------------------------------------------------------------------------

# Your Anthropic API key — get one at https://console.anthropic.com
# Used for the conversation engine and background extraction (Claude Haiku).
ANTHROPIC_API_KEY="sk-ant-..."

# -----------------------------------------------------------------------------
# VOYAGE AI
# -----------------------------------------------------------------------------

# Your Voyage AI API key — get one at https://dash.voyageai.com
# Used for generating conversation embeddings (voyage-3-lite, 512 dimensions).
VOYAGE_API_KEY=""

# -----------------------------------------------------------------------------
# AUTHENTICATION (Better Auth)
# -----------------------------------------------------------------------------

# A random 32+ character secret used to sign session tokens.
# Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET="random-secret-here"

# The base URL of your app — used for origin validation and redirects.
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app  (no trailing slash)
BETTER_AUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# UPSTASH REDIS (Rate Limiting)
# -----------------------------------------------------------------------------

# Upstash Redis credentials — get them at https://console.upstash.com
# Used for distributed rate limiting across all AI-backed API routes.
# Create a Redis database and copy the REST API credentials from the dashboard.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# -----------------------------------------------------------------------------
# PUBLIC VARIABLES (safe to expose to the browser — prefix NEXT_PUBLIC_)
# -----------------------------------------------------------------------------

# The full URL of your app, used for generating absolute URLs client-side.
# [OPTIONAL — defaults to http://localhost:3000]
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# VERCEL (set automatically by Vercel — do not set manually in production)
# -----------------------------------------------------------------------------

# VERCEL_URL is injected by Vercel at runtime.
# Do not define this in your .env files.
# VERCEL_URL=
