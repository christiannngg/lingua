// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  userLanguages UserLanguage[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model UserLanguage {
  id         String   @id @default(cuid())
  userId     String
  language   String   // "es" | "it"
  isActive   Boolean  @default(true)
  cefrLevel String   @default("A1")
  assessmentCompleted Boolean @default(false)  // ← ADD THIS
  assessmentStartedAt DateTime?                // ← ADD THIS (for analytics later)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessmentHistory AssessmentHistory[]
  conversations     Conversation[]

  vocabularyItems   VocabularyItem[]

  grammarMasteries  UserGrammarMastery[]
  grammarErrors     GrammarError[]

  weeklySummary WeeklySummary?

  @@unique([userId, language])  // prevents duplicate language entries per user
  @@index([userId])
  @@map("user_languages")
}

model AssessmentHistory {
  id             String   @id @default(cuid())
  userLanguageId String
  cefrLevel      String
  takenAt        DateTime @default(now())

  userLanguage UserLanguage @relation(fields: [userLanguageId], references: [id], onDelete: Cascade)

  @@map("assessment_history")
}

model Conversation {
  id             String    @id @default(cuid())
  userLanguageId String
  title          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  userLanguage   UserLanguage @relation(fields: [userLanguageId], references: [id], onDelete: Cascade)
  messages       Message[]
  vocabularyItems   VocabularyItem[]

  grammarErrors     GrammarError[]
  
  conversationEmbedding ConversationEmbedding?

  @@index([userLanguageId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model VocabularyItem {
  id                   String    @id @default(cuid())
  userLanguageId       String
  word                 String
  translation          String
  partOfSpeech         String?
  exampleSentence      String?   @db.Text
  sourceConversationId String?

  // ── FSRS scheduling fields ──────────────────────────────────────────────
  // state mirrors CardState enum values: "NEW" | "LEARNING" | "REVIEW" | "RELEARNING"
  state       String    @default("NEW")
  stability   Float     @default(0)
  difficulty  Float     @default(0)
  reps        Int       @default(0)
  lapses      Int       @default(0)
  lastReview  DateTime?
  nextReview  DateTime?

  createdAt DateTime @default(now())

  userLanguage       UserLanguage @relation(fields: [userLanguageId], references: [id], onDelete: Cascade)
  sourceConversation Conversation? @relation(fields: [sourceConversationId], references: [id], onDelete: SetNull)

  @@unique([userLanguageId, word])
  @@index([userLanguageId])
  @@index([nextReview])   // daily review queue queries filter by this
  @@map("vocabulary_items")
}

model GrammarConcept {
  id          String   @id @default(cuid())
  language    String   // "es" | "it"
  name        String   // matches GRAMMAR_CONCEPTS keys exactly
  description String

  masteries   UserGrammarMastery[]
  errors      GrammarError[]

  @@unique([language, name], name: "language_name")
  @@index([language])
  @@map("grammar_concepts")
}

model UserGrammarMastery {
  id               String   @id @default(cuid())
  userLanguageId   String
  grammarConceptId String
  errorCount       Int      @default(0)
  lastSeenAt       DateTime

  userLanguage   UserLanguage   @relation(fields: [userLanguageId], references: [id], onDelete: Cascade)
  grammarConcept GrammarConcept @relation(fields: [grammarConceptId], references: [id], onDelete: Cascade)

  @@unique([userLanguageId, grammarConceptId])
  @@index([userLanguageId])
  @@map("user_grammar_mastery")
}

model GrammarError {
  id               String   @id @default(cuid())
  userLanguageId   String
  grammarConceptId String
  conversationId   String
  userSentence     String   @db.Text
  correction       String   @db.Text
  explanation      String   @db.Text
  createdAt        DateTime @default(now())

  userLanguage   UserLanguage   @relation(fields: [userLanguageId], references: [id], onDelete: Cascade)
  grammarConcept GrammarConcept @relation(fields: [grammarConceptId], references: [id], onDelete: Cascade)
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([userLanguageId])
  @@index([conversationId])
  @@map("grammar_errors")
}

model ConversationEmbedding {
  id             String   @id @default(cuid())
  conversationId String   @unique
  summary        String   @db.Text
  embedding      Unsupported("vector(512)")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("conversation_embeddings")
}

model WeeklySummary {
  id             String   @id @default(cuid())
  userLanguageId String
  content        String   @db.Text
  generatedAt    DateTime @default(now())

  userLanguage UserLanguage @relation(fields: [userLanguageId], references: [id], onDelete: Cascade)

  @@unique([userLanguageId])
  @@map("weekly_summaries")
}